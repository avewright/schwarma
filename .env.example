# ─── Schwarma Hub — Production Environment Variables ────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is git-ignored.
#
# All SCHWARMA_* variables are read by HubConfig.from_env().
# See schwarma/hub/config.py for the full list.

# ─── Session Secret (REQUIRED for production) ──────────────────────────
# A random 64-character string used to sign browser session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left empty, one is auto-generated at startup — but it won't persist
# across container restarts, logging out all users.
SCHWARMA_SESSION_SECRET=

# ─── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection string.  The docker-compose default is:
#   postgresql://schwarma:schwarma@postgres:5432/schwarma
# For production, use a strong password and consider SSL:
#   postgresql://schwarma:<strong-password>@db-host:5432/schwarma
SCHWARMA_DATABASE_URL=postgresql://schwarma:schwarma@localhost:5432/schwarma

# Database SSL mode for managed databases (e.g. AWS RDS, Cloud SQL).
# Values: "" (disabled), "require", "verify-ca", "verify-full"
# For RDS: use "require" (RDS enforces TLS by default) or "verify-full"
# with the RDS combined CA bundle.
SCHWARMA_DATABASE_SSL=
# Path to CA certificate bundle (only needed for verify-ca / verify-full).
# AWS RDS bundle: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
SCHWARMA_DATABASE_SSL_CA=

# ─── CORS / Allowed Origins (REQUIRED for production) ──────────────────
# Comma-separated list of origins allowed to make requests.
#   "auto"                        — localhost only (dev/CI default)
#   "https://hub.schwarma.dev" — your production domain
#   "*"                           — allow all (NEVER use in production)
SCHWARMA_ALLOWED_ORIGINS=auto

# ─── Google OAuth (optional — enables "Sign in with Google") ───────────
# Create credentials at https://console.cloud.google.com/apis/credentials
SCHWARMA_GOOGLE_CLIENT_ID=
SCHWARMA_GOOGLE_CLIENT_SECRET=
SCHWARMA_GOOGLE_REDIRECT_URI=http://localhost:8741/auth/google/callback

# ─── GitHub OAuth (optional — enables "Sign in with GitHub") ───────────
# Create an OAuth App at https://github.com/settings/developers
SCHWARMA_GITHUB_CLIENT_ID=
SCHWARMA_GITHUB_CLIENT_SECRET=
SCHWARMA_GITHUB_REDIRECT_URI=http://localhost:8741/auth/github/callback

# ─── SMTP (optional — enables email verification for local signup) ─────
# Without SMTP, local-signup users cannot verify their email
# and verification codes are only logged server-side (dev mode).
SCHWARMA_SMTP_HOST=
SCHWARMA_SMTP_PORT=587
SCHWARMA_SMTP_USER=
SCHWARMA_SMTP_PASSWORD=
SCHWARMA_SMTP_FROM=

# ─── TLS (optional — direct HTTPS without reverse proxy) ──────────────
# Usually you'd terminate TLS at the reverse proxy (nginx/Caddy).
# These are only needed for direct TLS on the hub's own ports.
SCHWARMA_TLS_CERT=
SCHWARMA_TLS_KEY=

# ─── Network ──────────────────────────────────────────────────────────
SCHWARMA_HOST=0.0.0.0
SCHWARMA_TCP_PORT=9741
SCHWARMA_HTTP_PORT=8741

# ─── Rate Limiting ────────────────────────────────────────────────────
# Max requests per IP per window (0 = disabled).
SCHWARMA_HTTP_RATE_LIMIT=100
SCHWARMA_HTTP_RATE_WINDOW=60
SCHWARMA_MAX_REQUEST_SIZE=1048576

# ─── Logging ──────────────────────────────────────────────────────────
# Level: DEBUG, INFO, WARNING, ERROR
# Format: "text" (human-readable) or "json" (structured, Prometheus-friendly)
SCHWARMA_LOG_LEVEL=INFO
SCHWARMA_LOG_FORMAT=text

# ─── Shutdown ─────────────────────────────────────────────────────────
# Seconds to drain in-flight requests before force-stopping.
SCHWARMA_SHUTDOWN_DRAIN=5

# ─── LLM keys (for agent bots — not used by the hub itself) ──────────
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=
# MINIMAX_MODEL=
